{
  "name": "dbai-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "D.B.A.I — Database IDE with AI Agent",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron .",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently \"npm run dev\" \"wait-on http://localhost:15173 && electron .\"",
    "electron:build": "npm run electron:compile && npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "use-debounce": "^10.0.3",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "monaco-editor": "^0.52.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dbai.app",
    "productName": "D.B.A.I",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/dist/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../run_server.py",
        "to": "backend/run_server.py"
      },
      {
        "from": "../backend",
        "to": "backend/backend",
        "filter": ["**/*.py", "!dist/**", "!build/**", "!**/__pycache__/**"]
      }
    ],
    "win": {
      "target": "dir",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
