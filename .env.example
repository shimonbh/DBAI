# ═══════════════════════════════════════════════════════════════════════════════
# DBAI — Environment Configuration Template
# Copy to .env and fill in your values. DO NOT commit .env to source control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────────
DBAI_HOST=127.0.0.1
DBAI_PORT=8000

# ── Data Storage ───────────────────────────────────────────────────────────────
# DBAI_DATA_DIR=C:/Users/yourname/AppData/Roaming/DBAI/data

# ── Query Defaults ─────────────────────────────────────────────────────────────
DBAI_DEFAULT_QUERY_LIMIT=1000
DBAI_QUERY_TIMEOUT_SEC=30

# ── Monitor ────────────────────────────────────────────────────────────────────
DBAI_MONITOR_POLL_INTERVAL_SEC=2

# ── AI Providers ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=your_key_here
OPENAI_DEFAULT_MODEL=gpt-4o

GEMINI_API_KEY=your_key_here
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=your_key_here
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LM Studio — local OpenAI-compatible inference server (no real key needed)
# Start LM Studio, load a model, then enable the local server in LM Studio settings.
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_DEFAULT_MODEL=
LMSTUDIO_BASE_URL=http://localhost:1234/v1

DBAI_ACTIVE_AI_PROVIDER=anthropic

# ── UI Layout ──────────────────────────────────────────────────────────────────
VITE_LEFT_PANEL_WIDTH=280
VITE_EDITOR_HEIGHT_PERCENT=60
VITE_EDITOR_FONT_SIZE=14

# ── Theme & Colors ─────────────────────────────────────────────────────────────
VITE_COLOR_SCHEME=dark
VITE_ACCENT_COLOR=#4f9cf9
VITE_EDITOR_THEME=vs-dark
VITE_BG_PRIMARY=#1e1e2e
VITE_BG_SECONDARY=#181825
VITE_BG_PANEL=#313244
VITE_TEXT_PRIMARY=#cdd6f4
VITE_TEXT_MUTED=#6c7086
VITE_BORDER_COLOR=#45475a

# ── AI Inline Suggestion ───────────────────────────────────────────────────────
VITE_AUTOCOMPLETE_DEBOUNCE_MS=400
VITE_AUTOCOMPLETE_MAX_TOKENS=20

# ── Monitor ────────────────────────────────────────────────────────────────────
VITE_MONITOR_BUFFER_SIZE=60
